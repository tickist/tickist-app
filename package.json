{
  "name": "@tickist/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "dotenv -e .local_env -- nx serve tickist-web --host 0.0.0.0",
    "build": "nx build",
    "build:worker": "nx build tickist-web --configuration production",
    "test": "nx test",
    "deploy:worker": "wrangler deploy --config wrangler.toml",
    "db:reset": "npm run db:reset:local",
    "db:push:local": "dotenv -e .local_env -- sh -c 'npx supabase db push --db-url \"$SUPABASE_DB_URL\"'",
    "db:pull:local": "dotenv -e .local_env -- sh -c 'npx supabase db pull --db-url \"$SUPABASE_DB_URL\"'",
    "db:types:local": "dotenv -e .local_env -- node tools/scripts/generate-supabase-types.mjs",
    "db:reset:local": "dotenv -e .local_env -- sh -c 'npx supabase db reset --db-url \"$SUPABASE_DB_URL\"'",
    "db:push:remote": "dotenv -e .env -- sh -c 'npx supabase db push --db-url \"$SUPABASE_REMOTE_DB_URL\"'",
    "db:pull:remote": "dotenv -e .env -- sh -c 'npx supabase db pull --db-url \"$SUPABASE_REMOTE_DB_URL\"'",
    "db:types:remote": "dotenv -e .env -- sh -c 'SUPABASE_DB_URL=\"$SUPABASE_REMOTE_DB_URL\" node tools/scripts/generate-supabase-types.mjs'",
    "db:reset:remote": "dotenv -e .env -- sh -c 'npx supabase db reset --db-url \"$SUPABASE_REMOTE_DB_URL\"'",
    "supabase:init": "npx supabase init",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "migration:firebase:dry-run:local": "dotenv -e .local_env -- node scripts/firebase-migration/import.mjs --source ./backup_from_firebase --target local --scope active --dry-run",
    "migration:firebase:import:local": "dotenv -e .local_env -- node scripts/firebase-migration/import.mjs --source ./backup_from_firebase --target local --scope active",
    "migration:firebase:import:local:shared-password": "dotenv -e .local_env -- node scripts/firebase-migration/import.mjs --source ./backup_from_firebase --target local --scope active --prompt-shared-password",
    "migration:firebase:avatars:backfill:local": "dotenv -e .local_env -- node scripts/firebase-migration/backfill-avatar-metadata.mjs --target local",
    "migration:firebase:import:remote": "dotenv -e .env -- node scripts/firebase-migration/import.mjs --source ./backup_from_firebase --target remote --scope active",
    "migration:firebase:import:remote:shared-password": "dotenv -e .env -- node scripts/firebase-migration/import.mjs --source ./backup_from_firebase --target remote --scope active --prompt-shared-password",
    "migration:firebase:avatars:backfill:remote": "dotenv -e .env -- node scripts/firebase-migration/backfill-avatar-metadata.mjs --target remote",
    "migration:firebase:import:remote:with-resets": "dotenv -e .env -- node scripts/firebase-migration/import.mjs --source ./backup_from_firebase --target remote --scope active --send-reset-links"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "21.1.6",
    "@angular/compiler": "21.1.6",
    "@angular/core": "21.1.6",
    "@angular/forms": "21.1.6",
    "@angular/platform-browser": "21.1.6",
    "@angular/platform-browser-dynamic": "21.1.6",
    "@angular/platform-server": "21.1.6",
    "@angular/router": "21.1.6",
    "@angular/ssr": "21.1.5",
    "@supabase/supabase-js": "^2.89.0",
    "express": "^4.22.1",
    "lucide-angular": "^0.575.0",
    "rxjs": "~7.8.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.2.0",
    "@analogjs/vitest-angular": "^2.2.0",
    "@angular-devkit/build-angular": "21.1.5",
    "@angular-devkit/core": "21.1.5",
    "@angular-devkit/schematics": "21.1.5",
    "@angular/build": "21.1.5",
    "@angular/cli": "21.1.5",
    "@angular/compiler-cli": "21.1.6",
    "@angular/language-service": "21.1.6",
    "@eslint/js": "^9.39.2",
    "@nx/angular": "22.5.3",
    "@nx/devkit": "22.5.3",
    "@nx/eslint": "22.5.3",
    "@nx/eslint-plugin": "22.5.3",
    "@nx/js": "22.5.3",
    "@nx/playwright": "22.5.3",
    "@nx/vite": "22.5.3",
    "@nx/web": "22.5.3",
    "@nx/workspace": "22.5.3",
    "@playwright/test": "^1.57.0",
    "@schematics/angular": "21.1.5",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.19",
    "@types/express": "^4.17.25",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.50.1",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "angular-eslint": "^21.1.0",
    "autoprefixer": "^10.4.23",
    "daisyui": "^5.5.14",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.8.3",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.5.3",
    "postcss": "^8.5.6",
    "postcss-nesting": "^13.0.2",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.4.19",
    "ts-node": "10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.50.1",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "nx": {
    "includedScripts": []
  }
}
