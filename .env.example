# Copy this file to .env and .local_env (ignored) and fill in project-specific values.
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_REMOTE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=service-role-key
ROUTINE_RUNNER_SECRET=replace-with-strong-random-secret
NG_APP_SUPABASE_URL=https://your-project-id.supabase.co
NG_APP_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Optional override; when omitted app derives it from NG_APP_SUPABASE_URL as <url>/functions/v1
NG_APP_SUPABASE_FUNCTIONS_URL=http://localhost:54321/functions/v1
